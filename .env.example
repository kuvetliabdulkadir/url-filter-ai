# PostgreSQL ayarlari
POSTGRES_USER=urlfilter
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=urlfilter
DATABASE_URL=postgresql://urlfilter:change_me_strong_password@db:5432/urlfilter

# Ollama ayarlari
# host.docker.internal container icinden host makineye erisimi saglar
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_API_KEY=ollama

# API guvenligi
# Disaridan (curl, postman) yazma islemleri icin gerekli
API_KEY=generate_a_long_random_string_here
# Frontend GET istekleri icin ayri, dusuk yetkili token
PUBLIC_READ_TOKEN=frontend-read-token-change-me

# CORS - virgulle ayrilmis izinli origin listesi
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Icerik cekme ayarlari
FETCH_TIMEOUT=10
MAX_CONTENT_LENGTH=5000

# Cache suresi (saat) - ayni URL kac saat sonra yeniden analiz edilsin
CACHE_TTL_HOURS=24
